{
  "exclude": [
    "dist/",
    "scratch/"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "npm:solid-js",
    "lib": ["dom", "dom.iterable", "deno.ns"],
    "strict": true,
    "types": [
      "npm:@types/chrome@^0.1.42"
    ],
    "verbatimModuleSyntax": true
  },
  "imports": {
    "fs": "node:fs",
    "hash-wasm": "npm:hash-wasm@^4.12.0",
    "jsdom": "npm:jsdom@^29.1.1",
    "path": "node:path",
    "solid-js": "npm:solid-js@^1.9.3",
    "solid-js/web": "npm:solid-js@^1.9.3/web",
    "esbuild": "npm:esbuild@^0.28.0",
    "esbuild-plugin-solid": "npm:esbuild-plugin-solid@^0.6.0",
    "sass": "npm:sass@^1.99.0",
    "adm-zip": "npm:adm-zip@^0.5.17",
    "zod": "npm:zod@^4.4.3",
    "otpauth": "npm:otpauth@^9.5.1",
    "qrcode-parser": "npm:qrcode-parser@^2.1.3",
    "@std/assert": "jsr:@std/assert@1",
    "@/": "./src/"
  },
  "tasks": {
    "build": "deno run --node-modules-dir=auto -A build.ts",
    "watch": "deno run --node-modules-dir=auto -A build.ts --watch",
    "test": "deno test -A",
    "bump-version": "deno run -A version.ts"
  },
  "fmt": {
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "plugins": [
      "./custom-rules-plugin.ts"
    ],
    "rules": {
      "tags": [
        "recommended",
        "jsx"
      ],
      "exclude": [
        "no-window",
        "no-window-prefix",
        "jsx-boolean-value",
        "jsx-button-has-type"
      ]
    }
  }
}
